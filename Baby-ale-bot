  const chatId = msg.chat.id; const name = msg.from.first_name || 'amig@';
  if (db) { try { await db.collection('telegramUsers').doc(String(msg.from.id)).set({ chatId, name, username: msg.from.username||'', date: new Date().toISOString() }, { merge:true }); } catch(e){} }
  let welcome = `Hola ${name} ðŸ‘‹ Bienvenido a Baby Ale ðŸ’•\n\nUsa los botones para navegar:`;
